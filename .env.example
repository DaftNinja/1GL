# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — the app will not start without these
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Local example: postgres://postgres:password@localhost:5432/1giglabs
#
# NOTE: when running via docker-compose, do NOT set this variable.
# docker-compose constructs DATABASE_URL automatically from the POSTGRES_*
# variables below so it always points to the db service hostname.
DATABASE_URL=

# Secret used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# OpenAI API key for all AI report generation (company analyses, TAM, Power Trends).
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION (optional — defaults shown)
# ─────────────────────────────────────────────────────────────────────────────

# Server port. Defaults to 5000.
PORT=5000

# Comma-separated list of email addresses with admin privileges (audit log access).
# Example: admin@company.com,other@company.com
ADMIN_EMAILS=


# ─────────────────────────────────────────────────────────────────────────────
# EMAIL — required only for password-reset functionality
# ─────────────────────────────────────────────────────────────────────────────

# SMTP server hostname.
# Examples: smtp.sendgrid.net | smtp.mailgun.org | smtp.gmail.com
SMTP_HOST=

# SMTP port. Common values: 587 (STARTTLS), 465 (SSL), 25 (unencrypted).
# Defaults to 587.
SMTP_PORT=587

# SMTP authentication username (often your email address or API key).
SMTP_USER=

# SMTP authentication password or API key.
SMTP_PASS=

# From address shown in outbound emails.
# Defaults to SMTP_USER if not set.
SMTP_FROM=


# ─────────────────────────────────────────────────────────────────────────────
# DOCKER COMPOSE — only needed when running via docker-compose
# These replace DATABASE_URL; docker-compose builds the URL from them.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL superuser name (default: postgres).
POSTGRES_USER=postgres

# PostgreSQL password — REQUIRED, no default.
POSTGRES_PASSWORD=

# PostgreSQL database name (default: 1giglabs).
POSTGRES_DB=1giglabs


# ─────────────────────────────────────────────────────────────────────────────
# GRID & ENERGY DATA APIs — all optional
# The app degrades gracefully when these are absent; affected map layers
# and dashboard panels will show loading errors or be hidden.
# ─────────────────────────────────────────────────────────────────────────────

# ENTSO-E Transparency Platform.
# Powers: cross-border physical flows map, electricity price charts.
# Register at: https://transparency.entsoe.eu/
ENTSOE_API_KEY=

# UK Power Networks (UKPN) — OpenDataSoft API.
# Powers: UKPN data centre layer, grid/primary substation layer, DFES headroom.
# Request access at: https://ukpowernetworks.opendatasoft.com/
UKPN_API_KEY=

# National Grid Electricity Distribution (NGED).
# Powers: NGED network capacity, opportunity map, and generation register layers.
# Either variable name is accepted.
NGED_API_KEY=
# NATIONAL_GRID_API_KEY=

# SSEN NERDA API (Scottish and Southern Electricity Networks).
# Powers: SSEN substation headroom and DC probability layers.
SSEN_NERDA_API_KEY=

# Northern Power Grid (NPg) — OpenDataSoft API.
# Powers: NPg transformer utilisation and NDP headroom layers.
NPG_API_KEY=

# Electricity North West (ENW) — OpenDataSoft API.
# Powers: ENW BSP/PRY substation headroom layer.
ENW_API_KEY=

# RTE France — electricity generation and grid data.
# Powers: French grid data in the Power Trends and map layers.
# Register at: https://data.rte-france.com/
RTE_API_KEY=

# Fingrid (Finland) — real-time grid data.
# Powers: Finland grid data in the Power Trends page.
# Register at: https://data.fingrid.fi/
FINGRID_API_KEY=

# NED (Nationaal Energie Dashboard) — Netherlands electricity data.
# Powers: Netherlands grid data in the Power Trends page.
NED_API_KEY=

# US Energy Information Administration (EIA) — v2 API.
# Powers: US BA interchange flow map, generation by fuel type, retail prices, demand charts.
# Register at: https://www.eia.gov/opendata/
EIA_API_KEY=

# EPİAŞ (EXIST) Energy Exchange Istanbul — Turkey Electricity Market.
# Powers: Turkey day-ahead prices (fills ENTSO-E gap), real-time generation, consumption.
# Register at: https://kayit.epias.com.tr/epias-transparency-platform-registration-form
EPIAS_USERNAME=
EPIAS_PASSWORD=

# Ember Climate — energy mix and transition data.
# Powers: Ember energy mix charts.
# Register at: https://ember-climate.org/data/
EMBER_API_KEY=

# Open Energy Platform (OEP) — MODEX wind cost benchmarks.
# The OEP API is publicly accessible; this key is optional.
# Register at: https://openenergyplatform.org/
OEP_API_KEY=

# HeiGIT OpenRouteService — routing calculations.
# Register at: https://openrouteservice.org/
HEIGIT_API_KEY=

# Mapbox token used to refresh the Baxtel data centre tile cache.
# Only required if you need to re-fetch Baxtel tiles via POST /api/baxtel/refresh.
# Obtain at: https://account.mapbox.com/
BAXTEL_MAPBOX_TOKEN=
