From 709c56e5fe909f2eae530aafce80861f4b542672 Mon Sep 17 00:00:00 2001
From: Andrew McCreath <andrew@1giglabs.dev>
Date: Mon, 20 Apr 2026 10:02:56 +0000
Subject: [PATCH] Add remaining European countries to country dropdown

Expand GIGLABS_COUNTRIES (shared/schema.ts) to cover the rest of
Europe alphabetically, in addition to the existing UK, US, Brazil,
France, Netherlands and Sweden entries. Several of the new entries
(Ireland, Germany, Spain, Norway, Finland) already had country-
specific chart blocks wired up in PowerTrends.tsx but were not
selectable from the dropdown.

Also extend COUNTRY_CODE_MAP in server/worldBankData.ts with ISO
3166-1 alpha-2 codes for each new European country, so World Bank
indicator lookups resolve correctly for them.
---
 server/worldBankData.ts | 29 ++++++++++++++++++++++++++
 shared/schema.ts        | 45 +++++++++++++++++++++++++++++++++++++++--
 2 files changed, 72 insertions(+), 2 deletions(-)

diff --git a/server/worldBankData.ts b/server/worldBankData.ts
index b3e9b78..0f2b502 100644
--- a/server/worldBankData.ts
+++ b/server/worldBankData.ts
@@ -44,6 +44,35 @@ const COUNTRY_CODE_MAP: Record<string, string> = {
